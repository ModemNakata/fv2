DBUSER=
DBPASS=
DBNAME=
DATABASE_URL=postgres://user:pass@127.0.0.1:5432/name
SESSION_SECRET=

S3_ENDPOINT=http://192.168.1.188:9000
# PUBLIC_S3_ENDPOINT=https://local.test # deprecated
S3_ACCESS_KEY=rustfsadmin
S3_SECRET_KEY=rustfsadmin
S3_REGION=us-east-1
S3_BUCKET=fevid
S3_BUCKET_ORIGIN=fevid-orig

# REDIS_PASS=

# Upload size limits (bytes): 10GB for videos, 5GB for galleries
MAX_UPLOAD_SIZE_VIDEO=10737418240
MAX_UPLOAD_SIZE_GALLERY=5368709120
MAX_UPLOAD_IMAGES_COUNT=100

# Cryptowrap (crypto payment processor)
